# Copy to .env in project root or backend/ — never commit real values.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Groq Whisper when OpenAI Whisper fails or OPENAI_API_KEY is unset
GROQ_WHISPER_MODEL=whisper-large-v3

# Open-source speech-to-text on the server (faster-whisper / Whisper weights). No API key.
# First run downloads the model. Use with video or audio WebM uploads.
LOCAL_WHISPER=0
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
# GPU example: LOCAL_WHISPER_DEVICE=cuda LOCAL_WHISPER_COMPUTE_TYPE=float16
LOCAL_WHISPER_COMPUTE_TYPE=int8

# Hugging Face (OpenAI-compatible router); third fallback after Gemini & Groq
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
MISTRAL_API_KEY=

# Qdrant Cloud: cluster HTTPS URL + API key (JWT)
QDRANT_URL=
QDRANT_API_KEY=

PORT=5050
# Leave unset for default SQLite under backend/instance/. If you use Postgres, paste the
# full URL from your host (Render/Supabase/Neon) — not a template like ...@HOST:5432/...
# DATABASE_URL=
SECRET_KEY=change-me-in-production

# Optional: Supabase Storage for recordings (keeps clips off ephemeral disk).
# Dashboard → Storage → create private bucket (e.g. interview-recordings). Use service role only on the server.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=interview-recordings

# Optional: admin JSON list + download any recording (header X-Admin-Key)
# GET /api/admin/recordings
# GET /api/admin/recording/<recording_id>/media
ADMIN_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
MAX_UPLOAD_MB=25
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Production: absolute path to frontend/dist after `npm run build` (same server as API).
# Docker image sets this automatically. Leave empty for API-only (dev).
FRONTEND_DIST=

# Frontend build-time only: full API origin if UI is hosted separately (e.g. https://api.example.com).
# Leave empty when UI and /api share the same host (Docker or reverse proxy).
# VITE_API_BASE=
