# Copy to .env in project root or backend/ — never commit real values.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Groq Whisper when OpenAI Whisper fails or OPENAI_API_KEY is unset
GROQ_WHISPER_MODEL=whisper-large-v3

# Hugging Face (OpenAI-compatible router); third fallback after Gemini & Groq
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
MISTRAL_API_KEY=

# Qdrant Cloud: cluster HTTPS URL + API key (JWT)
QDRANT_URL=
QDRANT_API_KEY=

PORT=5050
DATABASE_URL=
SECRET_KEY=change-me-in-production
GEMINI_MODEL=gemini-2.0-flash
MAX_UPLOAD_MB=25
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Production: absolute path to frontend/dist after `npm run build` (same server as API).
# Docker image sets this automatically. Leave empty for API-only (dev).
FRONTEND_DIST=

# Frontend build-time only: full API origin if UI is hosted separately (e.g. https://api.example.com).
# Leave empty when UI and /api share the same host (Docker or reverse proxy).
# VITE_API_BASE=
